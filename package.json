{
  "name": "claude-desktop",
  "version": "1.0.0",
  "description": "Claude Desktop for Linux — a native wrapper around claude.ai",
  "main": "dist/main/main.js",
  "author": {
    "name": "ben",
    "email": "ben@localhost"
  },
  "license": "MIT",
  "scripts": {
    "build": "tsc",
    "start": "bun run build && electron .",
    "dev": "tsc && electron .",
    "dist": "tsc && npx electron-builder --linux",
    "dist:deb": "tsc && npx electron-builder --linux deb",
    "dist:appimage": "tsc && npx electron-builder --linux AppImage",
    "dist:rpm": "tsc && npx electron-builder --linux rpm",
    "icons": "node scripts/generate-icons.mjs"
  },
  "build": {
    "appId": "com.claude.desktop",
    "productName": "Claude Desktop",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "assets/**/*"
    ],
    "linux": {
      "target": [
        "AppImage",
        "deb"
      ],
      "icon": "assets/icons",
      "category": "Network",
      "synopsis": "Claude AI Desktop Client for Linux",
      "desktop": {
        "entry": {
          "Name": "Claude Desktop",
          "Comment": "Claude AI Desktop Client",
          "Terminal": "false",
          "Type": "Application",
          "Categories": "Network;Chat;InstantMessaging;",
          "StartupWMClass": "claude-desktop"
        }
      }
    },
    "deb": {
      "depends": [
        "libgtk-3-0",
        "libnotify4",
        "libnss3",
        "libxss1",
        "libxtst6",
        "xdg-utils",
        "libatspi2.0-0",
        "libuuid1"
      ]
    }
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "electron": "^34.0.0",
    "electron-builder": "^26.8.1",
    "typescript": "^5.7.0"
  }
}
